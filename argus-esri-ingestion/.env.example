# ──────────────────────────────────────────────────────────
# Argus Esri Ingestion — Environment Template
# Copy this file to .env and fill in your credentials.
# ──────────────────────────────────────────────────────────

# ArcGIS Online credentials (required for authenticated endpoints)
# Leave blank if only querying public layers (IMF PortWatch is public)
ARCGIS_USERNAME=
ARCGIS_PASSWORD=

# Output mode: "file" writes /data/ports.json | "http" starts local server
OUTPUT_MODE=file

# HTTP server port (only used when OUTPUT_MODE=http)
PORT=3747

# Poll interval in milliseconds (min 300000 = 5 min, recommended 600000 = 10 min)
# Set to 0 to run once and exit (same as --once flag)
POLL_INTERVAL_MS=600000

# Optional: ArcGIS portal URL (defaults to ArcGIS Online)
# ARCGIS_PORTAL_URL=https://www.arcgis.com
