# API Keys (All Free Tier - See docs/API_KEYS.md for setup instructions)

# NewsData.io - News aggregation API
NEWSDATA_API_KEY=pub_your_key_here

# VesselAPI - Maritime data
VESSELAPI_KEY=your_key_here

# Alpha Vantage - Stock & Forex data
ALPHA_VANTAGE_KEY=your_key_here

# FRED (Federal Reserve Economic Data)
FRED_API_KEY=your_key_here

# EIA (U.S. Energy Information Administration)
EIA_API_KEY=your_key_here

# Finnhub - Market data & crypto
FINNHUB_API_KEY=your_key_here

# Twelve Data - Commodities & exchanges
TWELVE_DATA_API_KEY=your_key_here

# Polygon.io - Market data
POLYGON_API_KEY=your_key_here

# Claude API (Optional - for AI analysis features)
ANTHROPIC_API_KEY=your_key_here

# Application Settings
DEBUG=false
CACHE_ENABLED=true
CORS_PROXY=codetabs

# CORS Proxy Options: codetabs, proxy.cors.sh, corsproxy.io, allorigins.win
# Note: App auto-falls back through proxy chain if primary fails
